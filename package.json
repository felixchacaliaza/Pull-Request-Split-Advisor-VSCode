{
  "name": "pr-split-advisor-vscode",
  "displayName": "PR Split Advisor",
  "description": "Analiza tu working tree y sugiere cómo dividir tus cambios en Pull Requests revisables.",
  "version": "0.1.1",
  "publisher": "FelixChacaliaza",
  "repository": {
    "type": "git",
    "url": "https://github.com/felixchacaliaza/Pull-Request-Split-Advisor-VSCode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "images/icon.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prSplitAdvisor.analyze",
        "title": "Analizar cambios del working tree",
        "category": "PR Split Advisor",
        "icon": "$(git-pull-request)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "prSplitAdvisor.analyze"
        }
      ],
      "scm/title": [
        {
          "command": "prSplitAdvisor.analyze",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
